APP_NAME=bilifocus-backend
APP_VERSION=0.1.0
API_PREFIX=/api
DATABASE_URL=sqlite:///./data/bilifocus.db
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://frontend:3000
DEFAULT_SEARCH_LIMIT=20
BILIBILI_API_BASE_URL=https://api.bilibili.com
BILIBILI_WEB_REFERER=https://www.bilibili.com/
BILIBILI_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36
PROVIDER_TIMEOUT_SECONDS=8.0
REAL_PROVIDER_PAGE_SIZE=20
LLM_REFINEMENT_ENABLED=false
LLM_REFINEMENT_MAX_CANDIDATES=12
LLM_REFINEMENT_TIMEOUT_SECONDS=20
LLM_PROVIDER=volcengine
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=
LLM_MODEL=
LLM_REASONING_EFFORT=low
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=low
CREWAI_ENABLED=false
